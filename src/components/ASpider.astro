---
// A little spider that rappels down its web thread as you scroll.
---

<div class="a-spider js-spider" aria-hidden="true">
  <span class="a-spider__thread"></span>
  <svg class="a-spider__bug" viewBox="0 0 64 72">
    <g stroke="currentColor" stroke-width="2.4" stroke-linecap="round" fill="none">
      <path d="M26 32 C16 26 11 28 5 21" />
      <path d="M26 37 C14 35 8 39 2 36" />
      <path d="M26 43 C14 47 10 53 5 57" />
      <path d="M27 47 C19 56 16 62 13 68" />
      <path d="M38 32 C48 26 53 28 59 21" />
      <path d="M38 37 C50 35 56 39 62 36" />
      <path d="M38 43 C50 47 54 53 59 57" />
      <path d="M37 47 C45 56 48 62 51 68" />
    </g>
    <g fill="currentColor">
      <ellipse cx="32" cy="30" rx="7.5" ry="8.5" />
      <ellipse cx="32" cy="45" rx="10.5" ry="13" />
    </g>
  </svg>
</div>

<script>
  const el = document.querySelector('.js-spider') as HTMLElement
  if (el) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    let t = 0
    let cur = 70
    let target = 70

    const compute = () => {
      const max = (document.body.scrollHeight - window.innerHeight) || 1
      const p = Math.min(Math.max(window.scrollY / max, 0), 1)
      target = 60 + p * (window.innerHeight * 0.52)
    }

    const loop = () => {
      cur += (target - cur) * 0.08
      t += 0.02
      const sway = Math.sin(t) * 10
      const tilt = Math.sin(t * 1.3) * 5
      el.style.setProperty('--len', cur.toFixed(1) + 'px')
      el.style.setProperty('--sway', sway.toFixed(1) + 'px')
      el.style.setProperty('--tilt', tilt.toFixed(1) + 'deg')
      requestAnimationFrame(loop)
    }

    compute()
    window.addEventListener('scroll', compute, { passive: true })
    window.addEventListener('resize', compute)

    if (reduce) {
      el.style.setProperty('--len', '70px')
    } else {
      requestAnimationFrame(loop)
    }
  }
</script>

<style lang="scss">
  .a-spider {
    position: fixed;
    top: 0;
    left: 82%;
    z-index: 6;

    color: color(secondary);
    pointer-events: none;
    will-change: transform;
    transform: translateX(var(--sway, 0));

    @include mq(phone) {
      left: 86%;
    }

    &__thread {
      position: absolute;
      top: 0;
      left: 50%;

      width: 1px;
      height: var(--len, 70px);

      background: linear-gradient(
        to bottom,
        transparent,
        color(secondary) 18%,
        color(secondary)
      );
      transform: translateX(-50%);
      opacity: 0.55;
    }

    &__bug {
      position: absolute;
      top: var(--len, 70px);
      left: 50%;

      width: 1.85rem;
      height: auto;

      transform: translate(-50%, -28%) rotate(var(--tilt, 0));
      transform-origin: 50% -120%;

      filter: drop-shadow(0 0.35rem 0.5rem rgba(10, 0, 0, 0.28));

      @include mq(phone) {
        width: 1.5rem;
      }
    }
  }
</style>
