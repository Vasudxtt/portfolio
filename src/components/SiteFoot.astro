<footer class="site-foot">
  <a href="#top" class="site-foot__bye js-foot-link">
    <span class="site-foot__dot" aria-hidden="true"></span>
    <span class="site-foot__word"><span class="js-foot-bye">Goodbye</span></span>
    <span class="u-sr-only">Vasudutt Pareek — back to top</span>
  </a>

  <div class="site-foot__meta">
    <span>Vasudutt Pareek © 2026</span>
    <span class="site-foot__top">Back to top ↑</span>
  </div>
</footer>

<script>
  const el = document.querySelector('.js-foot-bye') as HTMLElement
  if (el) {
    const byes = [
      'Goodbye', 'Au revoir', 'Adiós', 'Ciao', 'अलविदा',
      'さようなら', 'Tschüss', 'Tot ziens', '안녕', 'Adeus', 'До свидания',
    ]
    let i = 0
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    if (!reduce) {
      setInterval(() => {
        el.style.transition =
          'transform .34s cubic-bezier(.7,0,.3,1), opacity .34s ease'
        el.style.transform = 'translateY(-115%)'
        el.style.opacity = '0'
        setTimeout(() => {
          i = (i + 1) % byes.length
          el.textContent = byes[i]
          el.style.transition = 'none'
          el.style.transform = 'translateY(115%)'
          requestAnimationFrame(() => {
            el.style.transition =
              'transform .5s cubic-bezier(.16,1,.3,1), opacity .5s ease'
            el.style.transform = 'translateY(0)'
            el.style.opacity = '1'
          })
        }, 350)
      }, 2600)
    }
  }
</script>

