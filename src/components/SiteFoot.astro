      letter-spacing: -0.02em;
      text-transform: uppercase;
      text-decoration: none;

      transition: transform 0.6s ease(out-quint);
      will-change: transform;

      &:hover {
        transform: scale(1.04);
      }

      &:hover .site-foot__dot {
        transform: scale(1.4);
      }
    }

    &__dot {
      flex-shrink: 0;

      width: 0.16em;
