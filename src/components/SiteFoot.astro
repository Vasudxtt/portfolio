    }

    &__meta {
      @include flex(row, center, center);

      gap: 1.5rem;
      flex-wrap: wrap;

      font: 700 0.75rem / 1 font-family(fraktion);
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: color(secondary);

      @include mq(phone) {
        font-size: 0.625rem;
        gap: 1rem;
      }
    }

    &__top {
      position: relative;
      cursor: default;
      opacity: 0.6;
    }
  }
</style>
