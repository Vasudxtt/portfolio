<script>
  import Emitter from '../utils/Emitter'
  import Ticker from '../utils/Ticker'

  import { gsap } from 'gsap'

  class Section {
    el: HTMLElement
    themeToggle: HTMLElement
    palette: HTMLElement
    console: HTMLElement
    contrastMask: HTMLElement
    links: NodeListOf<HTMLElement>
    basePrimary: string
    coachShown: boolean
    coachVisible: boolean
    coachCooldownUntil: number

    messages: string[]
    message: string
    messageLineBreak: boolean
    lastMessage: string
    lastTypeTime: number
    writeDelay: number
    canWrite: boolean
    isPaused: boolean

    /**
     * Constructor
     */
    constructor() {
      // Elements
      this.el = document.querySelector('.site-head')
      this.themeToggle = document.querySelector('.js-theme-toggle')
      this.palette = document.querySelector('.js-palette')
      this.console = document.querySelector('.js-console')
      this.contrastMask = document.querySelector('.js-contrast-mask')
      this.links = this.el.querySelectorAll('.js-menu-link')

      // Properties
      this.messages = [
        'Compiling caffeine into code',
        'Shipping pixels from Mumbai',
        'Full-stack, full-send',
        'npm run dream',
        'Turning ideas into deploys',
        'MERN stack… online',
        'Bending React to my will',
        'Centering a div… nailed it',
        'Querying MongoDB for inspiration',
        'Pushing to main on a Friday',
        'Refactoring, then refactoring again',
        'Brewing the next big build',
        'console.log("let\'s build")',
        'Optimising every millisecond',
        'Designing like it matters',
        'Crafting clean, fast, kind code',
        'From zero to deployed',
        'Chai loaded. Focus engaged.',
        'Make it work. Make it beautiful.',
        'Building things people remember',
      ]
      this.message = ''
      this.messageLineBreak = false
      this.lastMessage = ''
      this.lastTypeTime = 0
      this.writeDelay = 0
      this.canWrite = false
      this.isPaused = true

      // Init
      Ticker.nextTick(this.init, this)
    }

    /**
     * Init
     */
    init() {
      this.restoreColor()
      this.bindEvents()

      // scroll-driven colour fade — the site gently lightens/darkens toward the footer
      if (!this.basePrimary) this.basePrimary = this.currentPrimary()
      this.applyShade()
      Emitter.on('scroll', this.applyShade, this)

      // the colour nudge reappears whenever the visitor scrolls back up to the header
      Emitter.on('scroll', this.updateCoachOnScroll, this)

      // coach fallback — fires even if the 'intro' event is missed
      setTimeout(() => this.maybeShowCoach(), 6500)
    }

    /**
     * Bind events
     */
    bindEvents() {
      this.themeToggle.addEventListener('click', (e) => {
        e.stopPropagation()
        const open = this.palette.classList.toggle('is-open')
        this.palette.setAttribute('aria-hidden', String(!open))
        this.dismissCoach()
      })

      const nameEl = this.palette.querySelector('.js-sw-name')
      this.palette.querySelectorAll('.js-sw').forEach((sw) => {
        sw.addEventListener('click', () => this.applyColor(sw.getAttribute('data-c')))
        sw.addEventListener('mouseenter', () => {
          if (nameEl) nameEl.textContent = sw.getAttribute('data-name')
        })
      })

      const custom = this.palette.querySelector('.js-sw-custom') as HTMLInputElement
      if (custom) custom.addEventListener('input', () => this.applyColor(custom.value))

      const random = this.palette.querySelector('.js-sw-random')
      if (random)
        random.addEventListener('click', () => {
          const h = Math.floor(Math.random() * 360)
          const s = 62 + Math.random() * 32
          const l = 42 + Math.random() * 16
          this.applyColor(this.hslToHex(h, s, l))
        })

      const reset = this.palette.querySelector('.js-sw-reset')
      if (reset) reset.addEventListener('click', () => this.applyColor('#f40c3f'))

      document.addEventListener('click', (e) => {
        if (
          this.palette.classList.contains('is-open') &&
          !this.el.contains(e.target as Node)
        ) {
          this.palette.classList.remove('is-open')
          this.palette.setAttribute('aria-hidden', 'true')
        }
      })

      this.links.forEach((link) => {
        link.addEventListener('click', this.moveToSection.bind(this))
      })

      document.addEventListener('intro', this.intro.bind(this), { once: true })

      this.el.addEventListener('intersect', this.onIntersect.bind(this), {
        passive: true,
      })
    }

    /**
     * Intersect handler
     */
    onIntersect(e) {
      this.isPaused = !e.detail.isIntersecting

      if (this.isPaused) {
        Emitter.off('tick', this.updateConsole, this)
      } else {
        Emitter.on('tick', this.updateConsole, this)
      }
    }

    /**
     * Intro
     */
    intro() {
      const logo = this.el.querySelector('.js-logo')
      const menuItems = this.el.querySelectorAll('.js-menu-item')
      const qrCode = this.el.querySelector('.js-qr-code')

      const items = [logo, ...menuItems]

      const tl = gsap.timeline()

      tl.set(this.el, {
        opacity: 1,
      })

      tl.from(
        this.el,
        {
          y: '-100%',
          duration: 1.5,
          ease: 'expo.inOut',
        },
        1
      )

      tl.from(
        items,
        {
          y: '-100%',
          duration: 1.5,
          ease: 'expo.out',
          stagger: 0.1,
        },
        1.5
      )

      tl.fromTo(
        qrCode,
        {
          '--bg-p': '0%',
        },
        {
          '--bg-p': '100%',
          duration: 1.5,
          ease: 'expo.out',
        },
        1.75
      )

      tl.call(
        () => {
          this.canWrite = true
        },
        null,
        1.5
      )

      // onboarding coach — nudge first-time visitors to try the colour picker
      this.maybeShowCoach()
    }

    /**
     * Show the onboarding coach the first time (after the intro), then let the
     * scroll watcher bring it back whenever the visitor returns to the header.
     */
    maybeShowCoach() {
      if (this.coachShown) return
      this.coachShown = true
      setTimeout(() => this.showCoach(), 1100)
    }

    /**
     * Reveal the colour-picker nudge
     */
    showCoach() {
      const coach = this.el.querySelector('.js-coach')
      const theme = this.el.querySelector('.sb-theme')
      if (!coach || this.coachVisible) return
      // don't pop while the palette is already open
      if (this.palette && this.palette.classList.contains('is-open')) return

      this.coachVisible = true
      coach.classList.add('is-on')
      if (theme) theme.classList.add('is-hinting')
    }

    /**
     * Dismiss the onboarding coach (with a short cooldown before it can return)
     */
    dismissCoach() {
      const coach = this.el.querySelector('.js-coach')
      const theme = this.el.querySelector('.sb-theme')
      if (coach) coach.classList.remove('is-on')
      if (theme) theme.classList.remove('is-hinting')
      this.coachVisible = false
      this.coachCooldownUntil = Date.now() + 1200
    }

    /**
     * Scroll watcher — show the colour nudge near the top, hide it once the
     * visitor scrolls into the page. Fires on every Emitter 'scroll'.
     */
    updateCoachOnScroll() {
      const atTop = (window.scrollY || window.pageYOffset || 0) < 90
      if (atTop) {
        if (!this.coachVisible && this.coachShown && Date.now() > (this.coachCooldownUntil || 0)) {
          this.showCoach()
        }
      } else if (this.coachVisible) {
        this.dismissCoach()
      }
    }

    /**
     * Apply a custom theme colour live (auto-contrasting text)
     */
    applyColor(hex) {
      if (!hex) return

      const rgb = this.hexToRgb(hex)
      // bias toward dark text on vivid colours (matches the black-on-red brand);
      // only genuinely dark colours flip to light text
      const light = this.luminance(rgb) > 0.18
      const secondary = light ? '#160000' : '#fff2ed'
      const shadow = this.toRgbStr(this.mix(rgb, light ? 0.4 : 0.55, [0, 0, 0]))

      const root = document.documentElement
      root.classList.remove('theme-contrasted')
      root.style.setProperty('--color-primary', hex)
      root.style.setProperty('--color-secondary', secondary)
      root.style.setProperty('--color-shadow', shadow)

      const custom = this.palette.querySelector('.js-sw-custom') as HTMLInputElement
      if (custom && /^#[0-9a-f]{6}$/i.test(hex)) custom.value = hex

      // UI feedback — hex readout, active swatch, colour name
      const hexEl = this.palette.querySelector('.js-sw-hex')
      if (hexEl) hexEl.textContent = hex.toUpperCase()

      let matched = null
      this.palette.querySelectorAll('.js-sw').forEach((s) => {
        const on = (s.getAttribute('data-c') || '').toLowerCase() === hex.toLowerCase()
        s.classList.toggle('is-active', on)
        if (on) matched = s.getAttribute('data-name')
      })
      const nameEl = this.palette.querySelector('.js-sw-name')
      if (nameEl) nameEl.textContent = matched || 'Custom blend'

      this.basePrimary = hex

      try {
        localStorage.setItem('vp-color', hex)
        localStorage.setItem('vp-coach', 'done')
      } catch (e) {}
      this.dismissCoach()

      Emitter.emit('contrastchange', 'custom')
      window.dispatchEvent(new CustomEvent('vp-recolor', { detail: hex }))

      // re-apply the scroll fade from the new base colour
      this.applyShade()
    }

    hslToHex(h, s, l) {
      s /= 100
      l /= 100
      const a = s * Math.min(l, 1 - l)
      const f = (n) => {
        const k = (n + h / 30) % 12
        const c = l - a * Math.max(-1, Math.min(k - 3, 9 - k, 1))
        return Math.round(255 * c).toString(16).padStart(2, '0')
      }
      return '#' + f(0) + f(8) + f(4)
    }

    rgbToHsl(r, g, b) {
      r /= 255
      g /= 255
      b /= 255
      const max = Math.max(r, g, b)
      const min = Math.min(r, g, b)
      let h = 0
      let s = 0
      const l = (max + min) / 2
      if (max !== min) {
        const d = max - min
        s = l > 0.5 ? d / (2 - max - min) : d / (max + min)
        if (max === r) h = (g - b) / d + (g < b ? 6 : 0)
        else if (max === g) h = (b - r) / d + 2
        else h = (r - g) / d + 4
        h /= 6
      }
      return [h * 360, s * 100, l * 100]
    }

    currentPrimary() {
      const inline = document.documentElement.style.getPropertyValue('--color-primary').trim()
      if (inline) return inline
      const computed = getComputedStyle(document.documentElement)
        .getPropertyValue('--color-primary')
        .trim()
      return computed || '#f40c3f'
    }

    applyShade() {
      if (!this.basePrimary) return
      const p = Math.min(Math.max(window.scrollProgress || 0, 0), 1)
      const rgb = this.hexToRgb(this.basePrimary)
      const dark = this.luminance(rgb) < 0.45
      const [h, s, l0] = this.rgbToHsl(rgb[0], rgb[1], rgb[2])
      // gently lighten a dark theme (or darken a light one) toward the bottom — kept subtle
      // so it never collapses contrast against the (fixed) text colour
      const l = Math.min(90, Math.max(10, l0 + (dark ? 1 : -1) * p * 9))
      document.documentElement.style.setProperty('--color-primary', this.hslToHex(h, s, l))
    }

    /**
     * Restore a saved colour on load
     */
    restoreColor() {
      let saved = null
      try {
        saved = localStorage.getItem('vp-color')
      } catch (e) {}
      if (saved) this.applyColor(saved)
    }

    hexToRgb(hex) {
      hex = hex.replace('#', '')
      if (hex.length === 3) hex = hex.split('').map((c) => c + c).join('')
      const n = parseInt(hex, 16)
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255]
    }

    luminance([r, g, b]) {
      const a = [r, g, b].map((v) => {
        v /= 255
        return v <= 0.03928 ? v / 12.92 : Math.pow((v + 0.055) / 1.055, 2.4)
      })
      return 0.2126 * a[0] + 0.7152 * a[1] + 0.0722 * a[2]
    }

    mix(rgb, t, target) {
      return rgb.map((v, i) => Math.round(v + (target[i] - v) * t))
    }

    toRgbStr(rgb) {
      return 'rgb(' + rgb.join(',') + ')'
    }

    /**
     * Move to section
     */
    moveToSection(e) {
      e.preventDefault()

      const id = e.currentTarget.getAttribute('href')

      window.lenis.scrollTo(id, {
        duration: 1.5,
        easing: (t) =>
          t < 0.5 ? 16 * t * t * t * t * t : 1 + 16 * --t * t * t * t * t,
      })
    }

    /**
     * Update console
     */
    updateConsole(time) {
      if (!this.console) return
      if (!this.canWrite || time - this.lastTypeTime < this.writeDelay) {
        return
      }

      if (this.message === '') {
        this.message = this.getRandomMessage()
        this.writeDelay = 2000
      } else {
        if (this.message === this.lastMessage || this.messageLineBreak) {
          this.console.textContent += '\n'
        }

        const char = this.message.charAt(0)
        this.message = this.message.substring(1)

        if (char === ',') {
          this.writeDelay = 100
        } else if (char === ' ') {
          this.writeDelay = 100
        } else if (char === '') {
          this.writeDelay = 200
        } else if (char === '…') {
          this.writeDelay = 400
        } else if (char === '.') {
          this.writeDelay = 400
        } else {
          this.writeDelay = 20
        }

        this.console.textContent += char

        if (char === '…') {
          this.messageLineBreak = true
        } else {
          this.messageLineBreak = false
        }
      }

      this.console.textContent = this.console.textContent
        .split('\n')
        .slice(-5)
        .join('\n')

      this.lastTypeTime = time
    }

    /**
     * Get random message
     */
    getRandomMessage() {
      let message =
        this.messages[Math.floor(Math.random() * this.messages.length)]

      if (message === this.lastMessage) {
        message = this.getRandomMessage()
      }

      this.lastMessage = message

      return message
    }
  }

  new Section()
</script>

