      url: 'https://vasuduttpareek.netlify.app/',
      email: 'mailto:vasuduttpareek@gmail.com',
      telephone: '+91-94617-44900',
      address: { '@type': 'PostalAddress', addressLocality: 'Mumbai', addressCountry: 'IN' },
      alumniOf: { '@type': 'CollegeOrUniversity', name: 'VIT Vellore' },
      knowsAbout: ['React', 'Next.js', 'Astro', 'TypeScript', 'Tailwind CSS', 'GSAP', 'Three.js', 'Node.js', 'Express', 'Prisma', 'PostgreSQL', 'MongoDB', 'Redis', 'Docker', 'AWS', 'GitHub Actions', 'OpenAI API', 'LLM Integration', 'AI Agents', 'WordPress', 'Shopify', 'PHP'],
